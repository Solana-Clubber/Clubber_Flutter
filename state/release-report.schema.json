{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/state/release-report.schema.json",
  "title": "AI Harness Release Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "release_summary",
    "scope",
    "ship_recommendation"
  ],
  "properties": {
    "release_summary": {
      "type": "string"
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "checklist": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item",
          "status"
        ],
        "properties": {
          "item": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "blocked",
              "not-run"
            ]
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "manual_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gate",
          "status"
        ],
        "properties": {
          "gate": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "completed",
              "waived"
            ]
          }
        }
      }
    },
    "ship_recommendation": {
      "type": "string",
      "enum": [
        "ship",
        "ship-with-known-risks",
        "do-not-ship"
      ]
    },
    "follow_up": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
