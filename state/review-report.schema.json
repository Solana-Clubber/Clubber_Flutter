{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/state/review-report.schema.json",
  "title": "AI Harness Review Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_status",
    "goal",
    "scope"
  ],
  "properties": {
    "review_status": {
      "type": "string",
      "enum": [
        "approve",
        "approve-with-notes",
        "changes-requested"
      ]
    },
    "goal": {
      "type": "string"
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "issue",
          "required_action"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "file": {
            "type": "string"
          },
          "issue": {
            "type": "string"
          },
          "required_action": {
            "type": "string"
          }
        }
      }
    },
    "strengths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
