{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/state/command-run.schema.json",
  "title": "AI Harness Command Run State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "command",
    "status",
    "phase",
    "scope",
    "updated_at"
  ],
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "/analyze-system",
        "/refactor-code",
        "/improve-quality",
        "/ship-release"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "blocked",
        "failed",
        "completed"
      ]
    },
    "phase": {
      "type": "string",
      "enum": [
        "inspect",
        "plan",
        "edit",
        "verify",
        "review",
        "report"
      ]
    },
    "goal": {
      "type": "string"
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "runtime_lanes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "flutter",
          "ios",
          "macos",
          "networkextension",
          "concurrency",
          "web3",
          "mixed"
        ]
      }
    },
    "plan_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "touched_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "result"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "result": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "not-run"
            ]
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
