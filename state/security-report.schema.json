{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/state/security-report.schema.json",
  "title": "AI Harness Security Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "security_summary",
    "scope"
  ],
  "properties": {
    "security_summary": {
      "type": "string"
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "area",
          "issue",
          "remediation"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "area": {
            "type": "string"
          },
          "issue": {
            "type": "string"
          },
          "exploit_path": {
            "type": "string"
          },
          "remediation": {
            "type": "string"
          }
        }
      }
    },
    "verified_strengths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check",
          "result"
        ],
        "properties": {
          "check": {
            "type": "string"
          },
          "result": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "not-run"
            ]
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
